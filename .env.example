# Trading AI local environment template.
# Copy to .env and fill only the providers you intend to use.
# Defaults are paper-trading only, deterministic-fallback friendly, and safe for local startup.

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
DATABASE_PATH=strategy_library.db
MARKET_DATA_MODE=auto
MARKET_DATA_PROVIDER=ibkr
OPTIONS_DATA_PROVIDER=ibkr
ALLOW_HISTORICAL_BAR_FALLBACK=true
ALLOW_LIVE_QUOTE_REQUIRED=false
ALLOW_OPTIONS_WITHOUT_QUOTES=false
ENABLE_OPTIONS=false

# Scanner/runtime limits
SCAN_MAX_CONCURRENCY=5
SCAN_TICKER_TIMEOUT_SECONDS=15
SCAN_TOTAL_TIMEOUT_SECONDS=180

# ---------------------------------------------------------------------------
# IBKR/TWS read-only market data
# ---------------------------------------------------------------------------
IBKR_HOST=127.0.0.1
IBKR_PORT=7496
IBKR_CLIENT_ID=123
IBKR_READ_ONLY=true
IBKR_USE_DELAYED_DATA=true
IBKR_TIMEOUT_SECONDS=10
IBKR_MAX_CONCURRENT_REQUESTS=3
IBKR_REQUESTS_PER_SECOND=2

# ---------------------------------------------------------------------------
# OpenAI planner and refinement
# ---------------------------------------------------------------------------
# Optional. When absent, ScanPlan proposal uses deterministic fallback.
AI_PLANNER_PROVIDER=auto
AI_REFINEMENT_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_PLANNER_MODEL=gpt-4.1-mini
OPENAI_PLANNER_TIMEOUT_SECONDS=20
OPENAI_REFINEMENT_MODEL=gpt-4.1-mini

# ---------------------------------------------------------------------------
# Current source-grounded research
# ---------------------------------------------------------------------------
# Optional. When absent, current research returns a clean unavailable/disabled status.
AI_RESEARCH_PROVIDER=auto
OPENAI_RESEARCH_MODEL=gpt-4.1-mini
OPENAI_RESEARCH_TIMEOUT_SECONDS=30
OPENAI_RESEARCH_MAX_TICKERS=3
OPENAI_RESEARCH_MAX_SOURCES=12
OPENAI_RESEARCH_SEARCH_CONTEXT_SIZE=medium
OPENAI_RESEARCH_BLOCKED_DOMAINS=
RESEARCH_CACHE_TTL_SECONDS=900

# ---------------------------------------------------------------------------
# SEC/news research
# ---------------------------------------------------------------------------
# SEC_USER_AGENT is required only if SEC_RESEARCH_ENABLED=true.
SEC_RESEARCH_ENABLED=false
SEC_RESEARCH_REQUIRED=false
SEC_USER_AGENT=
SEC_CACHE_ENABLED=true
SEC_CACHE_TTL_HOURS=24
SEC_REQUESTS_PER_SECOND=5
NEWS_RESEARCH_ENABLED=false
NEWS_RESEARCH_REQUIRED=false
NEWS_PROVIDER=ibkr_optional
IBKR_NEWS_DIAGNOSTIC_ENABLED=false
SHORT_INTEREST_ENABLED=true
SHORT_INTEREST_REQUIRED=false
FMP_API_KEY=

# ---------------------------------------------------------------------------
# Gemini compatibility
# ---------------------------------------------------------------------------
# Optional chat/narration compatibility. Deterministic tools still work without it.
ENABLE_GEMINI=false
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Memory
# ---------------------------------------------------------------------------
# Optional. SQLite remains the source of truth; Pinecone is semantic memory only.
MEMORY_ENABLED=false
MEMORY_REQUIRED=false
PINECONE_MEMORY_ENABLED=false
ENABLE_PINECONE_MEMORY=false
LOCAL_MEMORY_FALLBACK=true
MEMORY_EMBEDDING_PROVIDER=unavailable
MEMORY_MIN_SIMILARITY=0.82
MEMORY_EXPLANATION_MIN_SIMILARITY=0.75
MEMORY_MAX_AGE_DAYS=365
MEMORY_REQUIRE_VERIFIED_OUTCOMES=true
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=trading_ai
PINECONE_ENVIRONMENT=

# ---------------------------------------------------------------------------
# Scheduler and alerts
# ---------------------------------------------------------------------------
# Scheduler jobs are never started automatically on import.
SCHEDULER_ENABLED=false
SCHEDULER_TIMEZONE=America/New_York
SCHEDULER_MARKET_DAYS_ONLY=true
DEFAULT_PAPER_SCAN_DAY=MON
DEFAULT_PAPER_SCAN_TIME=09:00
DEFAULT_HEALTHCHECK_TIME=08:30

ALERTS_ENABLED=true
ALERT_CHANNELS=local
ALERT_WEBHOOK_URL=
ALERT_EMAIL_ENABLED=false
ALERT_MIN_SEVERITY=warning

# ---------------------------------------------------------------------------
# Stress testing
# ---------------------------------------------------------------------------
STRESS_TESTING_ENABLED=true
STRESS_TEST_JOB_ENABLED=false
STRESS_MAX_ACCEPTABLE_LOSS_R=3.0
STRESS_BLOCK_ON_EXTREME_DATA_FAILURE=true

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Optional alternate providers
# ---------------------------------------------------------------------------
POLYGON_API_KEY=
